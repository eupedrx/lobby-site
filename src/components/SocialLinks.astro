---
import { Icon } from 'astro-icon/components';

interface Props {
  links: Array<{
    name: string;
    icon: string;
    url: string;
  }>;
}

const { links } = Astro.props;
---

<div class="flex justify-center space-x-6">
  {
    links.map((link) => (
      <a
        href={link.url}
        class="flex items-center space-x-2 text-xl hover:text-white transition-all duration-300 hover:drop-shadow-[0_0_8px_white]"
        aria-label={link.name}
      >
        <Icon name={link.icon} class="w-5 h-5" />
      </a>
    ))
  }
</div>
