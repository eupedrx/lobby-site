---
import SocialLinks from './SocialLinks.astro';

interface Props {
  name: string;
  avatar: string;
  tagline: string;
  bio: string;
  socialLinks: Array<{
    name: string;
    icon: string;
    url: string;
  }>;
}

const { name, avatar, tagline, bio, socialLinks } = Astro.props;
---

<main
  id="content"
  class="relative z-10 flex flex-col items-center justify-center min-h-screen"
  style="opacity: 0; transform: translateY(80px) scale(0.85); transition: opacity 2.5s ease-out, transform 2.5s ease-out;"
>
  <div class="w-full max-w-sm p-8 rounded-2xl text-center glass-card">
    <div class="flex items-center justify-center w-32 h-32 mx-auto mb-6">
      <img
        src={avatar}
        alt="Avatar"
        class="w-full h-full object-cover rounded-full border-2 border-white/30 shadow-[0_0_5px_white]"
      />
    </div>

    <h1 id="title-typing" class="text-3xl font-bold mb-2 drop-shadow-lg"></h1>

    <span class="inline-block px-3 py-1 mb-6 text-xs border rounded-full">
      {tagline}
    </span>

    <p class="text-gray-300 mb-8 text-sm leading-relaxed" set:html={bio} />

    <SocialLinks links={socialLinks} />
  </div>

  <!-- Scroll indicator -->
  <button
    id="scroll-indicator"
    class="scroll-indicator"
    aria-label="Scroll para ver mais"
  >
    <svg
      id="scroll-arrow"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>
</main>

<style>
  .scroll-indicator {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.6);
    background: none;
    border: none;
    cursor: pointer;
    animation: bounce 2s infinite;
    transition: all 0.3s ease;
    padding: 0.5rem;
    z-index: 1000;
  }

  .scroll-indicator:hover {
    color: rgba(255, 255, 255, 1);
    transform: translateX(-50%) scale(1.2);
    filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.8));
  }

  .scroll-indicator.pointing-up #scroll-arrow {
    transform: rotate(180deg);
  }

  #scroll-arrow {
    transition: transform 0.3s ease;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateX(-50%) translateY(0);
    }
    40% {
      transform: translateX(-50%) translateY(-10px);
    }
    60% {
      transform: translateX(-50%) translateY(-5px);
    }
  }

  .scroll-indicator:hover {
    animation: none;
  }
</style>

<script>
  import { TypingEffect } from '../scripts/typing-effect';
  import { CardReveal } from '../scripts/card-reveal';

  const content = document.getElementById('content');
  const titleEl = document.getElementById('title-typing');
  const scrollIndicator = document.getElementById('scroll-indicator');

  if (content && titleEl) {
    const typingEffect = new TypingEffect(titleEl, 'satboy', 270);
    const cardReveal = new CardReveal(content, 120, () => {
      typingEffect.start();
    });

    function animate() {
      cardReveal.update();
      if (!cardReveal.isRevealed()) {
        requestAnimationFrame(animate);
      }
    }

    animate();
  }

  // Scroll bidirecional
  if (scrollIndicator) {
    let isPointingUp = false;

    scrollIndicator.addEventListener('click', () => {
      if (isPointingUp) {
        // Scroll para o topo
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        // Scroll para a seção de citações
        const quotesSection = document.querySelector('.quotes-section');
        if (quotesSection) {
          quotesSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });

    // Detectar posição do scroll e atualizar a direção da seta
    window.addEventListener('scroll', () => {
      const scrollPosition = window.scrollY;
      const shouldPointUp = scrollPosition > window.innerHeight / 2;

      if (shouldPointUp !== isPointingUp) {
        isPointingUp = shouldPointUp;
        if (isPointingUp) {
          scrollIndicator.classList.add('pointing-up');
          scrollIndicator.setAttribute('aria-label', 'Scroll para voltar ao topo');
        } else {
          scrollIndicator.classList.remove('pointing-up');
          scrollIndicator.setAttribute('aria-label', 'Scroll para ver mais');
        }
      }
    });
  }
</script>
