---
// src/pages/index.astro
import { Icon } from 'astro-icon/components';
import '../styles/global.css'; // Se tiver estilos globais, senão pode remover
---
<!DOCTYPE html>
<html lang="pt-br">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>satboy</title>
    <link href="https://fonts.googleapis.com/css2?family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-black text-white overflow-hidden font-['Courier_Prime']">

    <canvas id="starfield" class="fixed inset-0 z-0 w-full h-full"></canvas>

    <main id="content" class="relative z-10 flex items-center justify-center h-screen"
      style="opacity: 0; transform: translateY(80px) scale(0.85); transition: opacity 2.5s ease-out, transform 2.5s ease-out;">
      <div class="w-full max-w-sm p-8 rounded-2xl text-center glass-card">
        
        <div class="flex items-center justify-center w-32 h-32 mx-auto mb-6">
          <img
            src="/glasses.jpg"
            alt="Avatar"
            class="w-full h-full object-cover rounded-full border-2 border-white/30 shadow-[0_0_5px_white]"
          />
        </div>

        <h1 id="title-typing" class="text-3xl font-bold mb-2 drop-shadow-lg"></h1>
        
        <span class="inline-block px-3 py-1 mb-6 text-xs border rounded-full">
          tech enthusiast & fps player
        </span>

        <p class="text-gray-300 mb-8 text-sm leading-relaxed">
          god <span class="text-white drop-shadow-[0_0_5px_white]">did</span>.
        </p>

        <div class="flex justify-center space-x-6">
          <a href="https://discord.com/users/977624630187659264" class="flex items-center space-x-2 text-xl hover:text-white transition-all duration-300 hover:drop-shadow-[0_0_8px_white]">
            <Icon name="discord" class="w-5 h-5" />
          </a>
          <a href="https://github.com/eupedrx" class="flex items-center space-x-2 text-xl hover:text-white transition-all duration-300 hover:drop-shadow-[0_0_8px_white]">
            <Icon name="github" class="w-5 h-5" />
          </a>
		  <a href="https://steamcommunity.com/id/theylovesaturn/" class="flex items-center space-x-2 text-xl hover:text-white transition-all duration-300 hover:drop-shadow-[0_0_8px_white]">
            <Icon name="steam" class="w-5 h-5" />
          </a>
		  <a href="https://open.spotify.com/user/n0tf3twqx8xbjjzgnmntm89qu?si=667f173ba4634d82" class="flex items-center space-x-2 text-xl hover:text-white transition-all duration-300 hover:drop-shadow-[0_0_8px_white]">
            <Icon name="spotify" class="w-5 h-5" />
          </a>
        </div>

      </div>
    </main>


	
    <script>
      // --- PARTE 1: Aparição automática do card + efeito de digitação no título ---
      const content = document.getElementById('content');
      const titleEl = document.getElementById('title-typing');

      let frameCount = 0;
      let cardRevealed = false;

      // Configuração do efeito de digitação para "satboy"
      const typingText = 'satboy';
      let typingIndex = 0;
      let typingStarted = false;
      let typingTimer: number | undefined;

      function startTyping() {
        if (typingStarted || !titleEl) return;
        typingStarted = true;
        titleEl.textContent = '';
        typingTimer = window.setInterval(() => {
          if (typingIndex < typingText.length) {
            titleEl.textContent += typingText[typingIndex];
            typingIndex++;
          } else if (typingTimer) {
            window.clearInterval(typingTimer);
          }
        }, 270); // Velocidade de digitação (270ms por letra)
      }

      // --- PARTE 2: Lógica do Starfield (Fundo de Galáxia) ---
      const canvas = document.getElementById('starfield') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d');

      let width: number, height: number;
      
      // Configurações do efeito
      const numStars = 800; // Quantidade de estrelas (diminua se ficar lento)
      const speed = 0.05; // Velocidade da viagem
      let stars: Star[] = [];

      // Classe que define cada estrela
      class Star {
        x: number;
        y: number;
        z: number;
        xPrev: number;
        yPrev: number;

        constructor() {
          // Posição aleatória inicial em 3D
          // X e Y variam de -width a +width para espalhar bem
          this.x = (Math.random() - 0.5) * width * 2; 
          this.y = (Math.random() - 0.5) * height * 2;
          // Z é a profundidade (quanto maior, mais longe)
          this.z = Math.random() * width;
          this.xPrev = this.x;
          this.yPrev = this.y;
        }

        update() {
          // Move a estrela em direção à tela (diminuindo Z)
          this.z -= speed * 50; // Multiplicador para ajustar a sensação de velocidade
          
          // Se a estrela passar da tela (Z <= 0), reseta ela lá pro fundo
          if (this.z <= 0) {
            this.x = (Math.random() - 0.5) * width * 2;
            this.y = (Math.random() - 0.5) * height * 2;
            this.z = width;
            this.xPrev = this.x;
            this.yPrev = this.y;
          }
        }

        draw() {
          if (!ctx) return;

          // Matemática de perspectiva para transformar 3D em 2D
          const sx = (this.x / this.z) * (width / 2) + (width / 2);
          const sy = (this.y / this.z) * (height / 2) + (height / 2);

          // Calcula o rastro da estrela (opcional, dá mais sensação de velocidade)
          const px = (this.xPrev / (this.z + speed*50)) * (width / 2) + (width / 2);
          const py = (this.yPrev / (this.z + speed*50)) * (height / 2) + (height / 2);
          
          this.xPrev = this.x;
          this.yPrev = this.y;

          // Define o tamanho e brilho com base na proximidade
          // Estrelas mais perto (Z menor) são maiores e mais brilhantes
          const size = (1 - this.z / width) * 2.5;
          const opacity = (1 - this.z / width);

          if (sx > 0 && sx < width && sy > 0 && sy < height && size > 0) {
              ctx.beginPath();
              ctx.fillStyle = `rgba(255, 255, 255, ${opacity})`;
              // Desenha um pequeno círculo ou quadrado para a estrela
              ctx.arc(sx, sy, size < 0.1 ? 0.1 : size, 0, Math.PI * 2);
              ctx.fill();

              // Opcional: Desenhar o rastro (linha)
              // ctx.beginPath();
              // ctx.moveTo(px, py);
              // ctx.lineTo(sx, sy);
              // ctx.strokeStyle = `rgba(255, 255, 255, ${opacity * 0.5})`;
              // ctx.stroke();
          }
        }
      }

      // Função de inicialização
      function init() {
        if (!canvas) return;
        resize();
        stars = [];
        for (let i = 0; i < numStars; i++) {
          stars.push(new Star());
        }
        animate();
      }

      // Função de redimensionamento da janela
      function resize() {
        width = window.innerWidth;
        height = window.innerHeight;
        canvas.width = width;
        canvas.height = height;
      }

      // Loop de animação
      function animate() {
        if (!ctx) return;
        // Limpa o canvas com preto a cada frame
        ctx.fillStyle = "#000";
        ctx.fillRect(0, 0, width, height);

        // Atualiza e desenha cada estrela
        stars.forEach(star => {
          star.update();
          star.draw();
        });

        // Depois de alguns frames de "navegação" nas estrelas,
        // o card começa a aparecer suavemente e o título é digitado
        frameCount++;
        if (content && !cardRevealed && frameCount > 120) { // ~2 segundos a 60fps
          content.style.opacity = '1';
          content.style.transform = 'translateY(0) scale(1)';
          cardRevealed = true;
          startTyping();
        }

        requestAnimationFrame(animate);
      }

      // Inicia tudo e adiciona listener para resize
      window.addEventListener('resize', resize);
      // Pequeno delay para garantir que o DOM carregou
      setTimeout(init, 100);

    </script>

  <!-- Confete de aniversário (sem mexer no script existente) -->
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
  <script>
    window.addEventListener('load', () => {
      if (typeof (window as any).confetti !== 'function') return;

      const duration = 5 * 1000; // 5 segundos
      const animationEnd = Date.now() + duration;

      function frame() {
        (window as any).confetti({
          particleCount: 5,
          angle: 60,
          spread: 70,
          origin: { x: 0 },
        });

        (window as any).confetti({
          particleCount: 5,
          angle: 120,
          spread: 70,
          origin: { x: 1 },
        });

        if (Date.now() < animationEnd) {
          requestAnimationFrame(frame);
        }
      }

      // Dá um pequeno delay pra bater com a entrada do card
      setTimeout(frame, 2500);
    });
  </script>
  </body>
</html>